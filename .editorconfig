root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc,json5}]
indent_size = 2
indent_style = space

[*.nu]
indent_size = 4
indent_style = space

[*.pkl]
indent_size = 2
indent_style = space

[*.{yml,yaml}]
indent_size = 2
indent_style = space
